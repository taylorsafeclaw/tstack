---
// Magic UI / Aceternity-inspired terminal animation
// Self-contained: no React, no external deps
---

<div class="terminal-window" aria-hidden="true">
  <div class="terminal-bar">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
    <span class="terminal-title">zsh</span>
  </div>
  <div class="terminal-body">
    <div id="terminal-output"></div>
    <div class="terminal-cursor-line">
      <span class="prompt">❯</span>
      <span id="terminal-typing"></span>
      <span class="cursor blink">▋</span>
    </div>
  </div>
</div>

<style>
  .terminal-window {
    background: #0d0d0d;
    border: 1px solid rgba(163, 230, 53, 0.2);
    border-radius: 10px;
    width: 100%;
    max-width: 520px;
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 13px;
    line-height: 1.6;
    box-shadow:
      0 0 0 1px rgba(163, 230, 53, 0.05),
      0 20px 60px rgba(0, 0, 0, 0.6),
      0 0 40px rgba(163, 230, 53, 0.04);
    overflow: hidden;
  }

  .terminal-bar {
    background: #1a1a1a;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .red    { background: #ff5f57; }
  .yellow { background: #ffbd2e; }
  .green  { background: #28c840; }

  .terminal-title {
    flex: 1;
    text-align: center;
    color: rgba(255, 255, 255, 0.3);
    font-size: 11px;
    margin-right: 30px;
  }

  .terminal-body {
    padding: 16px 18px;
    min-height: 200px;
  }

  #terminal-output {
    color: rgba(255, 255, 255, 0.85);
  }

  .terminal-cursor-line {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
  }

  .prompt {
    color: #a3e635;
  }

  #terminal-typing {
    color: rgba(255, 255, 255, 0.9);
    white-space: pre;
  }

  .cursor {
    color: #a3e635;
    font-weight: 100;
  }

  .blink {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .line-cmd   { color: rgba(255,255,255,0.9); }
  .line-ok    { color: #a3e635; }
  .line-dim   { color: rgba(255,255,255,0.4); }
  .line-info  { color: #38bdf8; }
</style>

<script>
  type LineKind = 'cmd' | 'ok' | 'dim' | 'info';

  type AnyStep =
    | { type: 'type'; text: string; delay?: number }
    | { type: 'output'; lines: { text: string; kind: LineKind }[]; delay?: number }
    | { type: 'pause'; ms: number }
    | { type: 'clear' };

  const steps: AnyStep[] = [
    { type: 'type', text: 'tai install' },
    { type: 'pause', ms: 400 },
    {
      type: 'output', lines: [
        { text: '✓ Symlinked 23 commands', kind: 'ok' },
        { text: '✓ Symlinked 2 agents',   kind: 'ok' },
        { text: '✓ Symlinked 8 skills',   kind: 'ok' },
        { text: '✓ Quality gate active',  kind: 'ok' },
        { text: '', kind: 'dim' },
      ]
    },
    { type: 'pause', ms: 600 },
    { type: 'type', text: '/tai-feature "add auth flow"' },
    { type: 'pause', ms: 500 },
    {
      type: 'output', lines: [
        { text: '→ Planning...', kind: 'dim' },
        { text: '→ Spawning agents', kind: 'dim' },
        { text: '✓ 7 files changed', kind: 'ok' },
        { text: '✓ lint → build → test', kind: 'ok' },
        { text: '✓ PR #42 opened', kind: 'info' },
        { text: '', kind: 'dim' },
      ]
    },
    { type: 'pause', ms: 800 },
    { type: 'clear' },
  ];

  const outputEl = document.getElementById('terminal-output')!;
  const typingEl = document.getElementById('terminal-typing')!;
  const cursorEl = document.querySelector('.cursor') as HTMLElement;

  function sleep(ms: number) {
    return new Promise<void>(r => setTimeout(r, ms));
  }

  function appendLine(text: string, kind: LineKind) {
    const div = document.createElement('div');
    div.className = `line-${kind}`;
    if (kind === 'cmd') {
      const prompt = document.createElement('span');
      prompt.className = 'prompt';
      prompt.textContent = '❯ ';
      div.appendChild(prompt);
    }
    div.appendChild(document.createTextNode(text));
    outputEl.appendChild(div);
  }

  async function typeText(text: string) {
    typingEl.textContent = '';
    cursorEl.style.display = '';
    for (const ch of text) {
      typingEl.textContent += ch;
      await sleep(42 + Math.random() * 30);
    }
  }

  async function commitLine(text: string) {
    appendLine(text, 'cmd');
    typingEl.textContent = '';
  }

  function clearOutput() {
    while (outputEl.firstChild) {
      outputEl.removeChild(outputEl.firstChild);
    }
    typingEl.textContent = '';
  }

  async function runLoop() {
    while (true) {
      for (const step of steps) {
        if (step.type === 'type') {
          await typeText(step.text);
          await sleep(step.delay ?? 300);
          await commitLine(step.text);
        } else if (step.type === 'output') {
          cursorEl.style.display = 'none';
          const delay = step.delay ?? 80;
          for (const line of step.lines) {
            await sleep(delay);
            appendLine(line.text, line.kind);
          }
          cursorEl.style.display = '';
        } else if (step.type === 'pause') {
          await sleep(step.ms);
        } else if (step.type === 'clear') {
          await sleep(600);
          clearOutput();
        }
      }
    }
  }

  setTimeout(runLoop, 800);
</script>

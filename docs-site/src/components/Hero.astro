---
import TerminalAnimation from './TerminalAnimation.astro';

// Starlight v0.33 puts route data on Astro.locals.starlightRoute
const { data } = (Astro.locals as Record<string, unknown> & { starlightRoute?: { entry?: { data?: Record<string, unknown> } } }).starlightRoute?.entry ?? { data: undefined };
const hero = (data?.hero ?? {}) as { title?: string; tagline?: string; actions?: { link: string; variant?: string; text: string; icon?: string }[] };
const { title = data?.title as string | undefined, tagline, actions = [] } = hero;

---

{title && (
<section class="hero">
  <div class="hero-text">
    <h1 set:html={title} />
    {tagline && <p class="tagline">{tagline}</p>}

    {actions.length > 0 && (
      <div class="hero-actions">
        {actions.map((action) => (
          <a
            href={action.link}
            class:list={['action-btn', action.variant === 'primary' ? 'primary' : 'secondary']}
          >
            {action.text}
            {action.icon === 'right-arrow' && <span aria-hidden="true">→</span>}
            {action.icon === 'external' && <span aria-hidden="true">↗</span>}
          </a>
        ))}
      </div>
    )}
  </div>

  <div class="hero-visual">
    <TerminalAnimation />
  </div>
</section>
)}

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 4rem 0 3rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  h1 {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--sl-color-white);
    margin: 0 0 1rem;
    white-space: pre-line;
  }

  .tagline {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
    margin: 0 0 2rem;
    max-width: 38ch;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.25rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.15s;
  }
  .action-btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .primary {
    background: #a3e635;
    color: #000;
  }

  .secondary {
    background: transparent;
    color: var(--sl-color-white);
    border: 1px solid rgba(163, 230, 53, 0.4);
  }

  .hero-visual {
    flex: 1;
    max-width: 520px;
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      padding: 2.5rem 0 2rem;
      gap: 2rem;
    }
    .hero-visual {
      width: 100%;
      max-width: 100%;
    }
  }
</style>
